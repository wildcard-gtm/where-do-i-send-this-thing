# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Windows: created by bash 2>/dev/null redirection on Windows
/null
/NUL

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# agent results
results.json
results-experimental.json
final-results.json
dev.db

# docs/reports
*.md
!prompts/*.md
!CLAUDE.md
apidocs/

# private notes (gitignored)
notes/

# test/export files in root
/*.csv

# local test scripts
/tests/

# local scripts
/scripts/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# prisma
prisma/dev.db
prisma/dev.db-journal

# backups (db + source snapshots)
/backups/

# Chrome extensions (contain hardcoded keys)
chrome-extension/
chrome-extension-refresh/

# Local verification agent (not deployed)
/verification/

# Local PDF exporter
/exportpdf/

# Legacy server-side PDF generator
src/lib/pdf-generator.ts

# Template backups and working files (not used at runtime)
public/templates/originals/
public/templates/originals-backup/
public/templates/*.jpg~
public/templates/newsize.*
public/templates/fetch_rewards_logo.*
public/templates/reference-pose-6.png
public/templates/reference-pose-backup.png
public/templates/gpt-image-*
